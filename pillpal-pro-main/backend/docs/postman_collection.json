{
	"info": {
		"_postman_id": "pillpal-pro-collection",
		"name": "PillPal Pro API",
		"description": "Collection for testing PillPal Pro Backend",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Anshika\",\n    \"email\": \"anshika@example.com\",\n    \"password\": \"password123\",\n    \"timezone\": \"Asia/Kolkata\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"token\", jsonData.token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"anshika@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/users/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/users/profile",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"profile"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Medicines",
			"item": [
				{
					"name": "Get All Medicines",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/medicines",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"medicines"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Full Schedule",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/medicines/schedule?date=2025-12-24",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"medicines",
								"schedule"
							],
							"query": [
								{
									"key": "date",
									"value": "2025-12-24"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Add Medicine",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Dolo 650\",\n    \"dosage\": \"650mg\",\n    \"frequency\": \"Daily\",\n    \"times\": [\"09:00\", \"21:00\"],\n    \"startDate\": \"2025-12-24\",\n    \"currentStock\": 20\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/medicines",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"medicines"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Caregivers",
			"item": [
				{
					"name": "Add Caregiver",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Guardian Name\",\n    \"email\": \"guardian@example.com\",\n    \"relationship\": \"Parent\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/caregivers",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"caregivers"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000/api"
		},
		{
			"key": "token",
			"value": ""
		}
	]
}
